def agregar_juego(codigo, titulo, plataforma, genero,
                  clasificacion, multiplayer,
                  editor, precio, stock,
                  juegos, inventario):
    if buscar_codigo(codigo, juegos) != None:
        return False
    juegos[codigo] = [
        titulo,
        plataforma,
        genero,
        clasificacion.upper(),
        multiplayer,
        editor
    ]
    inventario[codigo] = [
        precio,
        stock
    ]
    return True
